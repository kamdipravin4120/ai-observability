{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "8.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "bargauge", "name": "Bar gauge", "version": "" },
    { "type": "panel", "id": "barchart", "name": "Bar chart", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": false,
      "keepTime": false,
      "tags": [],
      "targetBlank": true,
      "title": "AI Observability",
      "tooltip": "",
      "type": "link",
      "url": "/d/ai-observability-v4"
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "TOTALS",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#00e5cc" },
          "decimals": 0,
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#00e5cc", "value": null }] },
          "unit": "short",
          "custom": {}
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "TOTAL INPUT TOKENS",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "claude_total_input_tokens_all",
          "instant": true,
          "legendFormat": "Input",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#bd93f9" },
          "decimals": 0,
          "unit": "short",
          "custom": {}
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "TOTAL OUTPUT TOKENS",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "claude_total_output_tokens_all",
          "instant": true,
          "legendFormat": "Output",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#00ff41" },
          "decimals": 0,
          "unit": "short",
          "custom": {}
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "CACHE READ TOKENS",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "claude_total_cache_read_tokens_all",
          "instant": true,
          "legendFormat": "Cache Read",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#ffb700" },
          "decimals": 4,
          "unit": "currencyUSD",
          "custom": {}
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "TOTAL COST (EST.)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "claude_total_cost_usd_all",
          "instant": true,
          "legendFormat": "Cost",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#ff6ad5" },
          "decimals": 0,
          "unit": "short",
          "custom": {}
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "TOTAL SESSIONS",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "claude_total_sessions_all",
          "instant": true,
          "legendFormat": "Sessions",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#00e5cc" },
          "decimals": 0,
          "unit": "short",
          "custom": {}
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "PROJECTS",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "claude_total_projects_all",
          "instant": true,
          "legendFormat": "Projects",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "BY PROJECT",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineWidth": 1
          },
          "decimals": 0,
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 6 },
      "id": 10,
      "options": {
        "barRadius": 0,
        "barWidth": 0.7,
        "fullHighlight": false,
        "groupWidth": 0.7,
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "orientation": "horizontal",
        "showValue": "auto",
        "stacking": "normal",
        "tooltip": { "mode": "multi", "sort": "none" },
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 100
      },
      "title": "TOKENS BY PROJECT",
      "type": "barchart",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "claude_project_input_tokens_total",
          "instant": true,
          "legendFormat": "Input — {{project}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "claude_project_output_tokens_total",
          "instant": true,
          "legendFormat": "Output — {{project}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "claude_project_cache_read_tokens_total",
          "instant": true,
          "legendFormat": "Cache Read — {{project}}",
          "refId": "C"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "decimals": 4,
          "min": 0,
          "unit": "currencyUSD",
          "custom": {
            "fillOpacity": 80,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 6, "x": 12, "y": 6 },
      "id": 11,
      "options": {
        "displayMode": "lcd",
        "minVizHeight": 10,
        "minVizWidth": 0,
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true,
        "valueMode": "color"
      },
      "title": "COST BY PROJECT",
      "type": "bargauge",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sort_desc(claude_project_cost_usd_total)",
          "instant": true,
          "legendFormat": "{{project}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "decimals": 0,
          "min": 0,
          "unit": "short",
          "custom": {
            "fillOpacity": 80,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 6, "x": 18, "y": 6 },
      "id": 12,
      "options": {
        "displayMode": "lcd",
        "minVizHeight": 10,
        "minVizWidth": 0,
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true,
        "valueMode": "color"
      },
      "title": "SESSIONS BY PROJECT",
      "type": "bargauge",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sort_desc(claude_project_sessions_total)",
          "instant": true,
          "legendFormat": "{{project}}",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "id": 102,
      "title": "CACHE & MEMORY",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "decimals": 2,
          "min": 0,
          "max": 1,
          "unit": "percentunit",
          "custom": {
            "fillOpacity": 80,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "id": 20,
      "options": {
        "displayMode": "lcd",
        "minVizHeight": 10,
        "minVizWidth": 0,
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true,
        "valueMode": "color"
      },
      "title": "CACHE HIT RATE BY PROJECT  (cache_read / total_cache)",
      "type": "bargauge",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "claude_project_cache_read_tokens_total / (claude_project_cache_read_tokens_total + claude_project_cache_creation_tokens_total) > 0",
          "instant": true,
          "legendFormat": "{{project}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "decimals": 0,
          "min": 0,
          "unit": "short",
          "custom": {
            "fillOpacity": 80,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "id": 21,
      "options": {
        "displayMode": "lcd",
        "minVizHeight": 10,
        "minVizWidth": 0,
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true,
        "valueMode": "color"
      },
      "title": "MEMORY FILES BY PROJECT",
      "type": "bargauge",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sort_desc(claude_project_memory_files > 0)",
          "instant": true,
          "legendFormat": "{{project}}",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "id": 103,
      "title": "SESSION DETAIL",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "left",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50000 },
              { "color": "red", "value": 200000 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "cost_usd" },
            "properties": [
              { "id": "unit", "value": "currencyUSD" },
              { "id": "decimals", "value": 4 },
              { "id": "custom.width", "value": 90 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "input_tokens" },
            "properties": [{ "id": "custom.width", "value": 110 }]
          },
          {
            "matcher": { "id": "byName", "options": "output_tokens" },
            "properties": [{ "id": "custom.width", "value": 110 }]
          },
          {
            "matcher": { "id": "byName", "options": "project" },
            "properties": [
              { "id": "custom.width", "value": 150 },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "title" },
            "properties": [{ "id": "custom.width", "value": 280 }]
          },
          {
            "matcher": { "id": "byName", "options": "last_active" },
            "properties": [
              { "id": "unit", "value": "dateTimeFromNow" },
              { "id": "custom.width", "value": 130 }
            ]
          }
        ]
      },
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 26 },
      "id": 30,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "last_active" }]
      },
      "title": "ALL SESSIONS",
      "transformations": [
        {
          "id": "joinByLabels",
          "options": {
            "join": ["project", "session"],
            "value": "__name__"
          }
        },
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": ["project", "session", "title", "model",
                        "claude_session_input_tokens",
                        "claude_session_output_tokens",
                        "claude_session_cost_usd",
                        "claude_session_last_active_timestamp"]
            }
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "claude_session_input_tokens": "input_tokens",
              "claude_session_output_tokens": "output_tokens",
              "claude_session_cost_usd": "cost_usd",
              "claude_session_last_active_timestamp": "last_active"
            }
          }
        }
      ],
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "claude_session_input_tokens",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "claude_session_output_tokens",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "claude_session_cost_usd",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "claude_session_last_active_timestamp",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "D"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["claude", "sessions", "tokens", "cost"],
  "templating": { "list": [] },
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Claude Code Session Analytics",
  "uid": "claude-sessions-v1",
  "version": 1
}
